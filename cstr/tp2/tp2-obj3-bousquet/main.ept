open Extern (* declaration of external functions *)

const addr_hs:int = 0x2000 (* global constant *)

node hs_handler(hs:bool) returns (id:int) 
  var x :int;
let
  id = merge hs (true -> g()) (false -> f1(15 fby x));
  x = f2(id whenot hs);
tel

node main () returns () 
var hs : bool ; id : int ;
let 
  hs = read_bool(addr_hs) ;
  id = hs_handler(hs) ;
  () = act(id) ;
tel
